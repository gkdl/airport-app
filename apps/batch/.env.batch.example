# ── Oracle 접속 방식 (둘 중 하나만 사용) ─────────────────────────────────
# 방식 A: Wallet 사용 (운영 권장)
TNS_ADMIN=./wallet
DB_CONNECT_STRING=mydb_high
DB_USER=airport
DB_PASSWORD=password

# 방식 B: 직접 접속 (로컬 개발)
#DB_HOST=localhost
#DB_PORT=1521
#DB_SID=ORCL
#DB_USER=airport
#DB_PASSWORD=password

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 공공데이터포털 인증키 (https://www.data.go.kr) — 3개 서비스 모두 동일한 키 사용
INCHEON_API_KEY=your_data_go_kr_api_key
KAC_API_KEY=your_data_go_kr_api_key
KMA_API_KEY=your_data_go_kr_api_key

FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY=your_firebase_private_key

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
BATCH_CONCURRENCY=5
