# ── Oracle 접속 방식 (둘 중 하나만 사용) ─────────────────────────────────
# 방식 A: Wallet 사용 (운영 권장, kbo-summary 와 동일 DB)
#   1) apps/api/wallet/ 폴더에 cwallet.sso, ewallet.p12, tnsnames.ora, sqlnet.ora 배치
#      (kbo-summary 에서 사용하는 wallet 과 동일)
#   2) DB_PASSWORD 는 kbo DB_PASSWORD 와 동일
TNS_ADMIN=./wallet
DB_CONNECT_STRING=p0mpe7dp2i5vywqf_tp
DB_USER=SCRIPT
DB_PASSWORD=

# 방식 B: 직접 접속 (Wallet 없는 로컬 개발)
#DB_HOST=localhost
#DB_PORT=1521
#DB_SID=ORCL
#DB_USER=SCRIPT
#DB_PASSWORD=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=change-me-in-production
