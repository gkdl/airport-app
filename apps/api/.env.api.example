# ── Oracle 접속 방식 (둘 중 하나만 사용) ─────────────────────────────────
# 방식 A: Wallet 사용 (운영 권장)
#   1) apps/api/wallet/ 폴더에 cwallet.sso, ewallet.p12, tnsnames.ora, sqlnet.ora 배치
#   2) TNS_ADMIN 과 DB_CONNECT_STRING 설정 (tnsnames.ora 의 alias)
#   3) DB_HOST / DB_PORT / DB_SID 는 미사용
TNS_ADMIN=./wallet
DB_CONNECT_STRING=mydb_high
DB_USER=airport
DB_PASSWORD=password

# 방식 B: 직접 접속 (Wallet 없는 로컬 개발)
#DB_HOST=localhost
#DB_PORT=1521
#DB_SID=ORCL
#DB_USER=airport
#DB_PASSWORD=password

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001,https://admin.your-domain.com
